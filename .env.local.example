# ─── Supabase ───────────────────────────────────────────────
# Project URL and anon (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Google OAuth + Calendar ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# e.g. https://your-app.vercel.app/auth/callback
GOOGLE_REDIRECT_URI=

# ─── Cron security (optional) ───────────────────────────────
# Shared secret the Vercel Cron route checks before running sync.
CRON_SECRET=
